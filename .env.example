# -----------------------------
# APP / SERVER
# -----------------------------
# NODE_ENV
# Qué es: define el modo de ejecución del backend.
# Por qué existe: cambia comportamientos críticos (logs, seguridad, carga de secretos).
# Recomendación: usar `development` local y `production` en despliegue.
NODE_ENV=development

# PORT
# Qué es: puerto HTTP en el que escucha Express.
# Por qué existe: permite adaptar el servicio al runtime (local, Docker, ECS, etc).
# Recomendación: en cloud suele inyectarse automáticamente por la plataforma.
PORT=5001

# TRUST_PROXY
# Qué es: activa confianza en cabeceras de proxy (`X-Forwarded-*`) en Express.
# Por qué existe: detrás de ALB/Nginx/CloudFront necesitas IP/protocolo reales para
# rate limit, cookies seguras y redirecciones correctas.
# Recomendación: `true` en producción detrás de proxy, `false` en local.
TRUST_PROXY=false

# API_JSON_LIMIT
# Qué es: tamaño máximo de payload JSON aceptado por Express (`req.body`).
# Por qué existe: evita abuso de memoria/DoS y define límite operativo de entrada.
# Recomendación: aquí se deja alto por imágenes base64; si es muy bajo, tendrás 413;
# si es muy alto, aumenta consumo de memoria por request.
API_JSON_LIMIT=10mb

# -----------------------------
# AWS SECRETS MANAGER
# -----------------------------
# AWS_REGION
# Qué es: región de AWS usada para resolver servicios (Secrets Manager/S3 si aplica).
# Por qué existe: AWS SDK necesita región para ubicar recursos.
# Recomendación: usar la misma región de tu infraestructura principal.
AWS_REGION=us-east-1

# AWS_SECRETS_MANAGER_SECRET_ID
# Qué es: ID o ARN del secreto que contiene variables sensibles.
# Por qué existe: en `production` este backend carga secretos desde AWS antes de iniciar.
# Recomendación: guardar un JSON plano con llaves como `MONGO_URI`, `JWT_SECRET`, etc.
AWS_SECRETS_MANAGER_SECRET_ID=

# -----------------------------
# AWS S3 (IMÁGENES DE PROYECTOS Y RESEÑAS)
# -----------------------------
# AWS_S3_REGION
# Qué es: región del bucket S3 para uploads.
# Por qué existe: el cliente de S3 requiere región explícita para operar.
# Recomendación: mantenerla alineada con `AWS_REGION` cuando sea posible.
AWS_S3_REGION=us-east-1

# AWS_S3_BUCKET
# Qué es: nombre del bucket destino de imágenes.
# Por qué existe: define el contenedor físico de archivos del sistema.
# Recomendación: usar bucket dedicado por entorno (`dev`, `staging`, `prod`).
AWS_S3_BUCKET=

# AWS_S3_PUBLIC_BASE_URL
# Qué es: dominio público base para construir URLs de archivos.
# Por qué existe: permite servir imágenes por CloudFront/CDN o dominio personalizado.
# Recomendación: dejar vacío si usarás URL nativa de S3.
AWS_S3_PUBLIC_BASE_URL=

# S3_MAX_FILE_SIZE_MB
# Qué es: tamaño máximo permitido por imagen al subir base64.
# Por qué existe: protege recursos y evita cargas demasiado pesadas.
# Recomendación: 3-5MB para web suele ser suficiente si optimizas imágenes.
S3_MAX_FILE_SIZE_MB=5

# -----------------------------
# DATABASE
# -----------------------------
# MONGO_URI
# Qué es: cadena de conexión principal a MongoDB.
# Por qué existe: sin esta variable el backend no puede persistir datos.
# Recomendación: usar usuario con permisos mínimos y credenciales seguras.
MONGO_URI=mongodb://localhost:27017/backend_base

# -----------------------------
# AUTH / JWT
# -----------------------------
# JWT_SECRET
# Qué es: clave usada para firmar/verificar tokens JWT.
# Por qué existe: garantiza autenticidad de sesión; si se filtra, compromete seguridad.
# Recomendación: secreto largo, aleatorio y rotado periódicamente.
JWT_SECRET=change_this_super_secret

# TOKEN_EXPIRE
# Qué es: tiempo de vida del JWT.
# Por qué existe: limita duración de sesión y reduce riesgo por token comprometido.
# Recomendación: equilibrar UX y seguridad (ej. `7d` a `30d` según tu producto).
TOKEN_EXPIRE=30d

# EMAIL_VERIFICATION_EXPIRE_MS
# Qué es: tiempo de vida del token de verificación de correo en milisegundos.
# Por qué existe: evita que enlaces viejos sean válidos indefinidamente.
# Recomendación: 24 horas (86400000) para balancear seguridad y UX.
EMAIL_VERIFICATION_EXPIRE_MS=86400000

# COOKIE_SAMESITE
# Qué es: política SameSite de la cookie de autenticación.
# Por qué existe: protege contra CSRF y controla envío de cookie entre sitios.
# Recomendación:
# - `lax`: opción segura por defecto en la mayoría de apps
# - `strict`: máxima restricción
# - `none`: solo si frontend y backend están en dominios distintos con HTTPS
COOKIE_SAMESITE=lax

# -----------------------------
# CORS
# -----------------------------
# CORS_ORIGIN
# Qué es: lista blanca de orígenes permitidos (separados por coma).
# Por qué existe: evita que orígenes no autorizados consuman tu API en navegador.
# Recomendación: en producción definir dominios exactos, nunca dejarlo abierto.
CORS_ORIGIN=http://localhost:3000

# CORS_CREDENTIALS
# Qué es: habilita envío de credenciales en CORS (cookies, auth headers).
# Por qué existe: necesario cuando frontend usa sesión por cookie.
# Recomendación: `true` si usas cookie JWT; `false` en APIs totalmente públicas.
CORS_CREDENTIALS=true

# -----------------------------
# RATE LIMIT
# -----------------------------
# RATE_LIMIT_WINDOW_MS
# Qué es: duración de la ventana del rate limiter en milisegundos.
# Por qué existe: define el período sobre el cual se cuentan requests por IP.
# Ejemplo: 900000 = 15 minutos.
RATE_LIMIT_WINDOW_MS=900000

# RATE_LIMIT_MAX
# Qué es: máximo de requests por IP durante la ventana.
# Por qué existe: reduce abuso, scraping agresivo y fuerza bruta.
# Recomendación: ajustar según tráfico esperado y tipo de endpoints.
RATE_LIMIT_MAX=100

# -----------------------------
# FRONTEND / CLIENT
# -----------------------------
# CLIENT_URL
# Qué es: URL base del frontend público.
# Por qué existe: se usa para construir links de recuperación de contraseña.
# Recomendación: usar dominio real del frontend en cada entorno.
CLIENT_URL=http://localhost:3000

# -----------------------------
# SMTP (RECUPERACIÓN DE CONTRASEÑA)
# -----------------------------
# SMTP_HOST
# Qué es: host del proveedor SMTP.
# Por qué existe: endpoint para enviar correos del sistema.
# Recomendación: usar proveedor transaccional confiable en producción.
SMTP_HOST=smtp.mailtrap.io

# SMTP_PORT
# Qué es: puerto de conexión SMTP.
# Por qué existe: define canal de transporte seguro del correo.
# Recomendación:
# - Gmail/Office365: 587 (STARTTLS) o 465 (SSL/TLS)
# - Mailtrap: 2525/587 según tu inbox
SMTP_PORT=587

# SMTP_SECURE
# Qué es: fuerza conexión segura SMTP desde el inicio.
# Por qué existe: algunos proveedores exigen SSL/TLS estricto.
# Recomendación:
# - `true` cuando usas puerto 465
# - `false` cuando usas puerto 587 (STARTTLS)
SMTP_SECURE=false

# SMTP_EMAIL
# Qué es: usuario/identificador de autenticación SMTP.
# Por qué existe: el servidor de correo lo usa para autenticar el envío.
SMTP_EMAIL=your_smtp_user

# SMTP_PASSWORD
# Qué es: contraseña o app password SMTP.
# Por qué existe: completa autenticación para permitir envío.
# Recomendación: nunca hardcodear; siempre desde secretos.
SMTP_PASSWORD=your_smtp_password

# FROM_EMAIL
# Qué es: dirección remitente visible en el correo enviado.
# Por qué existe: define identidad del sistema ante el cliente final.
# Recomendación: usar dominio verificado para mejorar entregabilidad.
FROM_EMAIL=no-reply@example.com

# FROM_NAME
# Qué es: nombre amigable del remitente en bandeja de entrada.
# Por qué existe: mejora confianza y reconocimiento de marca.
FROM_NAME=Backend Base

# SMTP_CONNECTION_TIMEOUT_MS / SMTP_GREETING_TIMEOUT_MS / SMTP_SOCKET_TIMEOUT_MS
# Qué es: timeouts de conexión SMTP (milisegundos).
# Por qué existe: evita que requests de registro/login se queden colgados demasiado tiempo.
# Recomendación: mantener entre 8s y 20s.
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000
